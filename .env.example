# ─────────────────────────────────────────────────────────────────────────────
# Wunote.ai — 환경 변수 예시
# 이 파일을 .env.local 로 복사한 뒤 실제 값으로 교체하세요.
# .env.local 은 절대 Git 에 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# 대시보드: https://app.supabase.com → Settings → API
# NEXT_PUBLIC_ 접두사 변수는 브라우저에도 노출됩니다 (RLS 가 적용되므로 안전).
# SERVICE_ROLE_KEY 는 서버 전용 — 브라우저에 절대 노출하지 마세요.

NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# 대시보드: https://console.anthropic.com → API Keys
# lib/claude.ts 의 completeJSON / streamText 에서 사용합니다.

ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ── Resend (이메일) ───────────────────────────────────────────────────────────
# 대시보드: https://resend.com → API Keys
# 카드뉴스 이메일 발송(lib/email.ts)에 사용합니다.

RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
# 미설정 시 기본값: Wunote <noreply@wunote.ai>
RESEND_FROM_EMAIL=Wunote <noreply@wunote.ai>

# ── 카카오 알림 (OAuth 나에게 보내기) ─────────────────────────────────────────
# 대시보드: https://developers.kakao.com → 내 애플리케이션 → 앱 키
# 카카오 REST API 키(Client ID)와 Client Secret 을 입력하세요.
# 리다이렉트 URI 는 카카오 앱 설정 → 플랫폼 → Web 에도 동일하게 등록해야 합니다.

KAKAO_CLIENT_ID=YOUR_KAKAO_REST_API_KEY_HERE
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET_HERE
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/api/notifications/kakao/connect

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# 키 생성: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ 공개키는 ServiceWorker 구독 시 브라우저에서 사용합니다.
# VAPID_PRIVATE_KEY 는 서버에서 알림 서명 시 사용 — 절대 노출하지 마세요.

NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_HERE
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY_HERE
# 발신자 식별용 (RFC 형식: mailto:... 또는 https://...)
WEB_PUSH_SUBJECT=mailto:noreply@wunote.ai

# ── 번역 API (역방향 번역 비교 기능) ─────────────────────────────────────────
# 세 엔진(DeepL · Papago · OpenAI)이 병렬로 번역 결과를 생성합니다.
# 미사용 엔진은 빈 값으로 두면 해당 번역 결과가 생략됩니다.

# DeepL: https://www.deepl.com/pro-api
DEEPL_API_KEY=YOUR_DEEPL_API_KEY_HERE

# Papago (네이버 클라우드): https://api.ncloud-docs.com/docs/ai-naver-papagonmt
PAPAGO_CLIENT_ID=YOUR_PAPAGO_CLIENT_ID_HERE
PAPAGO_CLIENT_SECRET=YOUR_PAPAGO_CLIENT_SECRET_HERE

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# 번역에 사용할 모델 (기본값: gpt-4o-mini)
OPENAI_TRANSLATE_MODEL=gpt-4o-mini

# ── 앱 공통 ───────────────────────────────────────────────────────────────────

# 앱의 공개 URL — 카드뉴스 이메일 링크, 카카오 리다이렉트 URI 기본값에 사용됩니다.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron 작업 인증 시크릿 — Vercel Cron 등 외부 스케줄러가 API 를 호출할 때 검증합니다.
# 임의의 긴 문자열로 설정하세요 (예: openssl rand -hex 32).
CRON_SECRET=YOUR_CRON_SECRET_HERE
