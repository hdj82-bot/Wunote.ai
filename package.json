{
  "name": "wunote",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --local > types/database.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "icons:build": "powershell -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "sounds:gen": "powershell -ExecutionPolicy Bypass -File scripts/generate-sounds.ps1",
    "sounds:build": "node scripts/build-sounds.mjs",
    "pwa:check": "node scripts/check-pwa-manifest.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "cheerio": "^1.2.0",
    "howler": "^2.2.4",
    "mammoth": "^1.8.0",
    "next": "14.2.35",
    "next-intl": "^4.9.1",
    "pdf-parse": "^1.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "glob": "^10.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^20.17.6",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
